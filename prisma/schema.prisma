// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  REGISTRAR
  TEACHER
  STUDENT
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
}

enum AddressType {
  CURRENT
  PERMANENT
}

enum ParentType {
  FATHER
  MOTHER
  GUARDIAN
}

enum EnrollmentStatus {
  PENDING
  ENROLLED
  CANCELLED
}

enum DisabilityType {
  VISUAL_IMPAIRMENT_BLIND
  VISUAL_IMPAIRMENT_LOW_VISION
  HEARING_IMPAIRMENT
  LEARNING_DISABILITY
  INTELLECTUAL_DISABILITY
  AUTISM_SPECTRUM_DISORDER
  EMOTIONAL_BEHAVIORAL_DISORDER
  ORTHOPEDIC_PHYSICAL_HANDICAP
  SPEECH_LANGUAGE_DISORDER
  CEREBRAL_PALSY
  SPECIAL_HEALTH_PROBLEM_CHRONIC_DISEASE
  CANCER
  MULTIPLE_DISORDER
}

enum LearningMode {
  MODULAR_PRINT
  MODULAR_DIGITAL
  BLENDED
  FACE_TO_FACE
}

enum Semester {
  FIRST
  SECOND
}

enum Track {
  ACADEMIC
  TVL
  SPORTS
  ARTS_AND_DESIGN
}

enum Strand {
  STEM
  ABM
  HUMSS
  GAS
  TVL_ICT
  TVL_HE
  TVL_AGRI
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

model User {
  id                 Int     @id @default(autoincrement())
  username           String  @unique
  password           String
  role               Role
  mustChangePassword Boolean @default(true)
  isActive           Boolean @default(true)

  student Student?
  teacher Teacher?
  admin   Admin?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Teacher {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  employeeId String @unique

  assignments TeacherAssignment[]

  firstName     String
  lastName      String
  middleName    String?
  extensionName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  employeeId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id Int @id @default(autoincrement())

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentNumber String @unique

  firstName     String
  lastName      String
  middleName    String?
  extensionName String?

  enrollmentApplication EnrollmentApplication?
  enrollments           Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EnrollmentApplication {
  id Int @id @default(autoincrement())

  studentId Int?     @unique
  student   Student? @relation(fields: [studentId], references: [id])

  gradeLevel  Int
  hasLRN      Boolean
  isReturning Boolean @default(false)

  schoolYearId Int
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])

  psaNumber String?
  lrn       String?

  firstName     String
  middleName    String?
  lastName      String
  extensionName String?

  birthDate    DateTime
  gender       Gender
  placeOfBirth String

  isIP        Boolean @default(false)
  ipCommunity String?

  is4Ps       Boolean @default(false)
  householdId String?

  hasDisability Boolean @default(false)

  lastGradeCompleted Int?
  lastSchoolYear     String?
  lastSchoolAttended String?
  lastSchoolId       String?

  semester Semester?
  track    Track?
  strand   Strand?

  status ApplicationStatus @default(PENDING)

  approvedAt DateTime?
  rejectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  remarks String?

  addresses     EnrollmentApplicationAddress[]
  parents       EnrollmentApplicationParent[]
  disabilities  EnrollmentApplicationDisability[]
  learningModes EnrollmentApplicationLearningMode[]
}

model SchoolYear {
  id Int @id @default(autoincrement())

  name String @unique

  isCurrent Boolean @default(false)

  startYear Int
  endYear   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments           Enrollment[]
  curriculums           Curriculum[]
  enrollmentApplication EnrollmentApplication[]
  teachersAssignments   TeacherAssignment[]

  @@unique([startYear, endYear])
}

model EnrollmentApplicationAddress {
  id Int @id @default(autoincrement())

  enrollmentApplicationId Int
  enrollmentApplication   EnrollmentApplication @relation(fields: [enrollmentApplicationId], references: [id])

  type AddressType

  houseNo      String?
  street       String?
  sitio        String?
  barangay     String
  municipality String
  province     String
  country      String
  zipCode      String
}

model EnrollmentApplicationParent {
  id Int @id @default(autoincrement())

  enrollmentApplicationId Int
  enrollmentApplication   EnrollmentApplication @relation(fields: [enrollmentApplicationId], references: [id])

  type ParentType

  firstName  String
  middleName String?
  lastName   String

  contactNumber String?
}

model EnrollmentApplicationDisability {
  id Int @id @default(autoincrement())

  enrollmentApplicationId Int
  enrollmentApplication   EnrollmentApplication @relation(fields: [enrollmentApplicationId], references: [id])

  disabilityType DisabilityType
}

model EnrollmentApplicationLearningMode {
  id Int @id @default(autoincrement())

  enrollmentApplicationId Int
  enrollmentApplication   EnrollmentApplication @relation(fields: [enrollmentApplicationId], references: [id])

  learningMode LearningMode
}

model Subject {
  id Int @id @default(autoincrement())

  code String @unique

  name String @unique

  description String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curriculumSubjects CurriculumSubject[]
  sectionSubjects    SectionSubject[]
}

model Curriculum {
  id Int @id @default(autoincrement())

  curriculumName String

  gradeLevel Int

  track Track?

  strand Strand?

  schoolYearId Int

  schoolYear SchoolYear @relation(fields: [schoolYearId], references: [id])

  curriculumSubjects CurriculumSubject[]

  section Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gradeLevel, schoolYearId, track, strand])
}

model CurriculumSubject {
  curriculumId Int

  subjectId Int

  curriculum Curriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([curriculumId, subjectId])
}

model Section {
  id Int @id @default(autoincrement())

  name String

  capacity Int @default(40)

  isActive Boolean @default(true)

  curriculumId Int

  curriculum Curriculum @relation(fields: [curriculumId], references: [id])

  enrollments Enrollment[]

  sectionSubjects SectionSubject[]

  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, curriculumId])
}

model Enrollment {
  id Int @id @default(autoincrement())

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  schoolYearId Int
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])

  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id])

  status EnrollmentStatus @default(ENROLLED)

  enrolledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, schoolYearId])
}

model Room {
  id Int @id @default(autoincrement())

  name     String
  building String

  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SectionSubject {
  id Int @id @default(autoincrement())

  sectionId Int
  subjectId Int

  section Section @relation(fields: [sectionId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  teacherAssignment TeacherAssignment?

  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, subjectId])
}

model TeacherAssignment {
  id Int @id @default(autoincrement())

  teacherId Int
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  sectionSubjectId Int            @unique
  sectionSubject   SectionSubject @relation(fields: [sectionSubjectId], references: [id])

  schoolYearId Int
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Schedule {
  id Int @id @default(autoincrement())

  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id])

  roomId Int
  room   Room @relation(fields: [roomId], references: [id])

  sectionSubjectId Int
  sectionSubject   SectionSubject @relation(fields: [sectionSubjectId], references: [id])

  day DayOfWeek

  startTime DateTime
  endTime   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
